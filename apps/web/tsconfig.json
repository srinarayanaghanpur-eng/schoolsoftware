{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@sri-narayana/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@sri-narayana/shared/*": [
        "../../packages/shared/src/*"
      ],
      "firebase/auth": [
        "../../node_modules/@firebase/auth/dist/auth-public.d.ts"
      ]
    },
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
