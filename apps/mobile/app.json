{
  "expo": {
    "name": "Sri Narayana Staff Attendance",
    "slug": "sri-narayana-staff-attendance",
    "scheme": "sna",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "runtimeVersion": "1.0.0",
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Sri Narayana Staff Attendance to use your location for campus attendance."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Sri Narayana Staff Attendance to use your camera."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.srinarayana.attendance",
      "buildNumber": "1"
    },
    "android": {
      "versionCode": 1,
      "package": "com.srinarayana.attendance",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    }
  }
}
