rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == "admin";
    }

    match /teacher-profiles/{teacherId}/{fileName} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /attendance-selfies/{teacherId}/{fileName} {
      allow read: if isAdmin() || (signedIn() && request.auth.token.teacherId == teacherId);
      allow write: if signedIn() && request.auth.token.teacherId == teacherId;
    }
  }
}
